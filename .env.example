# TripMind — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# ── Phase 1: Data Generation ──────────────────────────────────────────────────
# OpenAI (paid — used gpt-4o-mini for synthetic data): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google AI Studio (free — used as eval judge): https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Phase 2: Agent LLM ───────────────────────────────────────────────────────
# DeepSeek (paid — used DeepSeek V4 Flash for multi-agent traces): https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ── Phase 2: MCP Servers ─────────────────────────────────────────────────────
# OpenRouteService (free): https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# ── Phase 4: Eval Judge ───────────────────────────────────────────────────────
# Groq (free tier — used for reasoning coherence judge): https://console.groq.com/keys
GROQ_API_KEY=

# ── Phase 3: HuggingFace (optional, for model upload) ────────────────────────
# HuggingFace Hub (free for public repos): https://huggingface.co/settings/tokens
HF_TOKEN=
